# ============================================================
# SmartFin — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Anthropic API
# ------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ------------------------------------------------------------
# LangSmith (Observability & Tracing)
# Sign up at https://smith.langchain.com
# ------------------------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=smartfin

# ------------------------------------------------------------
# Model Configuration
# Default model used by all agents unless overridden in config.py
# ------------------------------------------------------------
SMARTFIN_MODEL=claude-haiku-4-5
SMARTFIN_ENFORCE_APPROVED_MODELS=false

# ------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
SMARTFIN_LOG_FORMAT=plain
SMARTFIN_BACKEND_URL=http://localhost:8000

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
# PostgreSQL connection for LangGraph checkpoints + UI sessions
DATABASE_URL=postgresql://smartfin:smartfin@localhost:5432/smartfin

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
# Redis for LLM response caching
REDIS_URL=redis://localhost:6379/0
