# ============================================================
# SmartFin — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Anthropic API
# Scoped to the gateway container only — do NOT pass to backend
# once Module 2 (get_llm() migration) is complete.
# ------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ------------------------------------------------------------
# LiteLLM Gateway
# LITELLM_MASTER_KEY: secret used to manage the gateway (issue virtual keys,
#   view usage). Choose a strong random string, e.g.: openssl rand -hex 32
# LITELLM_VIRTUAL_KEY: a virtual key issued by the gateway for the backend.
#   Generate after first docker compose up:
#     curl -X POST http://localhost:4000/key/generate \
#       -H "Authorization: Bearer $LITELLM_MASTER_KEY" \
#       -H "Content-Type: application/json" \
#       -d '{"key_alias": "smartfin-backend", "models": ["claude-haiku-4-5", "claude-opus-4-8", "claude-sonnet-4-6", "claude-sonnet-4-5"]}'
#   Copy the returned "key" value here.
# ------------------------------------------------------------
LITELLM_MASTER_KEY=sk-master-changeme
LITELLM_VIRTUAL_KEY=sk-sf-virtual-changeme

# ------------------------------------------------------------
# OpenAI API (used for text-embedding-3-small in the memory module)
# ------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here

# ------------------------------------------------------------
# LangSmith (Observability & Tracing)
# Sign up at https://smith.langchain.com
# ------------------------------------------------------------
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=smartfin

# ------------------------------------------------------------
# Capability Eval Provider (OpenAI-compatible)
# Used by tests/evals and CI; does not route through LiteLLM Gateway
# ------------------------------------------------------------
SMARTFIN_EVAL_PROVIDER=openai-compatible
SMARTFIN_EVAL_BASE_URL=https://your-openai-compatible-provider.example.com/v1
SMARTFIN_EVAL_API_KEY=your_eval_provider_api_key_here
SMARTFIN_EVAL_MODEL=deepseek-v4-pro
SMARTFIN_EVAL_JUDGE_MODEL=deepseek-v4-pro
SMARTFIN_EVAL_SUITE=smoke

# ------------------------------------------------------------
# Model Registry
# Model selection is driven by config/model_registry.json.
# SMARTFIN_ENFORCE_APPROVED_MODELS controls whether ad-hoc model names
# are forced back to the registry default.
# ------------------------------------------------------------
SMARTFIN_ENFORCE_APPROVED_MODELS=false

# ------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
SMARTFIN_LOG_FORMAT=plain
SMARTFIN_BACKEND_URL=http://localhost:8000

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
# PostgreSQL connection for LangGraph checkpoints + UI sessions
DATABASE_URL=postgresql://smartfin:smartfin@localhost:5432/smartfin

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
# Redis for LLM response caching
REDIS_URL=redis://localhost:6379/0
