FROM node:20-alpine AS build

WORKDIR /app/ui

COPY ui/package.json ui/package-lock.json ./
RUN npm ci

COPY ui/ ./
RUN npm run build

FROM node:20-alpine

WORKDIR /app/ui
ENV NODE_ENV=production

COPY --from=build /app/ui/package.json ./package.json
COPY --from=build /app/ui/package-lock.json ./package-lock.json
COPY --from=build /app/ui/node_modules ./node_modules
COPY --from=build /app/ui/dist ./dist

EXPOSE 8501

CMD ["npm", "run", "preview", "--", "--host", "0.0.0.0", "--port", "8501"]
